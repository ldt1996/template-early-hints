{
	"extends": "@harperdb/code-guidelines/tsconfig.node.json",
	"compilerOptions": {
		"declaration": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"noImplicitAny": false,
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist", "tests"]
}
